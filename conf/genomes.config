params.analysis_modes = [
    wgs_numt_correction: [
        run_numt_correction: true,
        reference_set       : 'GRCh38+rCRS',
        datadir            : '/opt/clam/share/gsnap',
        mt_gsnap_db        : 'rCRS_gsnap',
        fasta              : '/hpcnfs/scratch/ED/genome/mitochondrion/rCRS.fa',
        mutserve_fasta     : '/opt/clam/share/reference/rCRS_NC_012920.1.fasta',
        mt_contig          : 'NC_012920.1',
        genomedir          : '/hpcnfs/scratch/ED/genome/clam_refs/gsnap_GRCh38_gencode49',
        nuc_gsnap_db       : 'hg38_gsnap',
        numt               : '/opt/clam/share/mitoscape/NUMTs_hg38.txt'
    ],

    rcrs_only: [
        run_numt_correction: false,
        reference_set       : 'rCRS',
        datadir            : '/opt/clam/share/gsnap',
        mt_gsnap_db        : 'rCRS_gsnap',
        fasta              : '/hpcnfs/scratch/ED/genome/mitochondrion/rCRS.fa',
        mutserve_fasta     : '/opt/clam/share/reference/rCRS_NC_012920.1.fasta',
        mt_contig          : 'NC_012920.1',
        genomedir          : null,
        nuc_gsnap_db       : null,
        numt               : null
    ]
]

def analysis_mode_aliases = [
    'wgs_numt_correction': 'wgs_numt_correction',
    'wgs-numt-correction': 'wgs_numt_correction',
    'wgs'                : 'wgs_numt_correction',
    'numt'               : 'wgs_numt_correction',
    'full'               : 'wgs_numt_correction',
    'grch38'             : 'wgs_numt_correction',
    'hg38'               : 'wgs_numt_correction',
    'rcrs_only'          : 'rcrs_only',
    'rcrs-only'          : 'rcrs_only',
    'mitochondrial_only' : 'rcrs_only',
    'mitochondrial-only' : 'rcrs_only',
    'short'              : 'rcrs_only',
    'rcrs'               : 'rcrs_only'
]

def requested_mode = (params.genome ?: params.analysis_mode ?: 'wgs_numt_correction').toString()
def selected_mode = analysis_mode_aliases[requested_mode.toLowerCase()]

if (selected_mode && params.analysis_modes[selected_mode]) {
    def selected = params.analysis_modes[selected_mode]

    params.analysis_mode = selected_mode
    params.genome = selected.reference_set
    params.reference_set = selected.reference_set
    params.run_numt_correction = selected.run_numt_correction
    params.datadir = selected.datadir
    params.mt_gsnap_db = selected.mt_gsnap_db
    params.fasta = selected.fasta
    params.mutserve_fasta = selected.mutserve_fasta
    params.mt_contig = selected.mt_contig
    params.genomedir = selected.genomedir
    params.nuc_gsnap_db = selected.nuc_gsnap_db
    params.numt = selected.numt
} else {
    params.analysis_mode = requested_mode
}
